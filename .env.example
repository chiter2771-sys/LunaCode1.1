# Backend
LUNACODE_WORKSPACE=/workspace
LUNACODE_MAX_RETRIES=3
LUNACODE_EXEC_TIMEOUT=30

# AI providers (never exposed to the frontend)
# Recommended: one OpenRouter key can route planner/coder/debugger requests to different models.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://lunacode.local
OPENROUTER_PLANNER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_CODER_MODEL=deepseek/deepseek-chat
OPENROUTER_DEBUGGER_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Optional direct provider keys. Used only when OPENROUTER_API_KEY is empty.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PLANNER_MODEL=qwen-plus
QWEN_DEBUGGER_MODEL=qwen-coder-plus
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CODER_MODEL=deepseek-coder

# Optional local dev frontend origin
FRONTEND_ORIGIN=http://localhost:5173
