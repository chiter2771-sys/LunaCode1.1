# Backend
LUNACODE_WORKSPACE=/workspace
LUNACODE_MAX_RETRIES=3
LUNACODE_EXEC_TIMEOUT=30

# AI providers (never exposed to the frontend)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PLANNER_MODEL=qwen-plus
QWEN_DEBUGGER_MODEL=qwen-coder-plus
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CODER_MODEL=deepseek-coder

# Optional local dev frontend origin
FRONTEND_ORIGIN=http://localhost:5173
